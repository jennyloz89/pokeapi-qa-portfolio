    {
      "name": "Regression Tests",
      "item": [
        {
          "name": "validation - pikachu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "// ─── Schema definition ───────────────────────────────────────\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"id\", \"name\", \"base_experience\", \"height\", \"weight\", \"types\", \"stats\", \"abilities\", \"sprites\"],\r",
                  "    properties: {\r",
                  "        id:              { type: \"number\" },\r",
                  "        name:            { type: \"string\" },\r",
                  "        base_experience: { type: \"number\" },\r",
                  "        height:          { type: \"number\" },\r",
                  "        weight:          { type: \"number\" },\r",
                  "        types: {\r",
                  "            type: \"array\",\r",
                  "            minItems: 1,\r",
                  "            items: {\r",
                  "                type: \"object\",\r",
                  "                required: [\"slot\", \"type\"],\r",
                  "                properties: {\r",
                  "                    slot: { type: \"number\" },\r",
                  "                    type: {\r",
                  "                        type: \"object\",\r",
                  "                        required: [\"name\", \"url\"],\r",
                  "                        properties: {\r",
                  "                            name: { type: \"string\" },\r",
                  "                            url:  { type: \"string\" }\r",
                  "                        }\r",
                  "                    }\r",
                  "                }\r",
                  "            }\r",
                  "        },\r",
                  "        stats: {\r",
                  "            type: \"array\",\r",
                  "            minItems: 6,\r",
                  "            items: {\r",
                  "                type: \"object\",\r",
                  "                required: [\"base_stat\", \"effort\", \"stat\"],\r",
                  "                properties: {\r",
                  "                    base_stat: { type: \"number\" },\r",
                  "                    effort:    { type: \"number\" },\r",
                  "                    stat: {\r",
                  "                        type: \"object\",\r",
                  "                        required: [\"name\", \"url\"]\r",
                  "                    }\r",
                  "                }\r",
                  "            }\r",
                  "        },\r",
                  "        abilities: {\r",
                  "            type: \"array\",\r",
                  "            minItems: 1,\r",
                  "            items: {\r",
                  "                type: \"object\",\r",
                  "                required: [\"ability\", \"is_hidden\", \"slot\"]\r",
                  "            }\r",
                  "        },\r",
                  "        sprites: {\r",
                  "            type: \"object\",\r",
                  "            required: [\"front_default\"],\r",
                  "            properties: {\r",
                  "                front_default: { type: \"string\" }\r",
                  "            }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "// ─── Tests ────────────────────────────────────────────────────\r",
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"JSON Schema es válido\", () => {\r",
                  "    pm.expect(tv4.validate(res, schema)).to.be.true;\r",
                  "    if (!tv4.validate(res, schema)) {\r",
                  "        console.error(\"Schema error:\", tv4.error);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Contrato estable: ID y nombre no cambian entre runs\", () => {\r",
                  "    pm.expect(res.id).to.eql(25);\r",
                  "    pm.expect(res.name).to.eql(\"pikachu\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Contrato estable: tipo siempre es electric\", () => {\r",
                  "    const types = res.types.map(t => t.type.name);\r",
                  "    pm.expect(types).to.include(\"electric\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Contrato estable: base_experience siempre es 112\", () => {\r",
                  "    pm.expect(res.base_experience).to.eql(112);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Contrato estable: tiene exactamente 6 stats\", () => {\r",
                  "    pm.expect(res.stats).to.have.lengthOf(6);\r",
                  "});\r",
                  "\r",
                  "// Guardar snapshot para comparar en siguiente run\r",
                  "pm.environment.set(\"snapshot_pikachu_id\",   res.id);\r",
                  "pm.environment.set(\"snapshot_pikachu_type\", res.types[0].type.name);\r",
                  "pm.environment.set(\"snapshot_pikachu_bexp\", res.base_experience);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
