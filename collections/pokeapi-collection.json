        {
          "name": "Equivalence: name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status 200 por nombre\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Guardar datos para comparar\r",
                  "pm.environment.set(\"charizard_by_name_id\",     res.id);\r",
                  "pm.environment.set(\"charizard_by_name_type\",   res.types[0].type.name);\r",
                  "pm.environment.set(\"charizard_by_name_height\", res.height);\r",
