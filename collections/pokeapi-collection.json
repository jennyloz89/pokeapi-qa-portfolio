          "name": "Pokémon list - page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Estructura de paginación correcta\", () => {\r",
                  "    pm.expect(res).to.have.all.keys(\"count\", \"next\", \"previous\", \"results\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Retorna exactamente 20 resultados\", () => {\r",
                  "    pm.expect(res.results).to.have.lengthOf(20);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total de pokémon es mayor o igual a 1302\", () => {\r",
                  "    pm.expect(res.count).to.be.at.least(1302);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Cada resultado tiene name y url\", () => {\r",
                  "    res.results.forEach((pokemon, i) => {\r",
                  "        pm.expect(pokemon, `Item ${i}`).to.have.all.keys(\"name\", \"url\");\r",
                  "        pm.expect(pokemon.name).to.be.a(\"string\").and.not.empty;\r",
                  "        pm.expect(pokemon.url).to.include(\"https://pokeapi.co/api/v2/pokemon/\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"next apunta a offset=20\", () => {\r",
                  "    pm.expect(res.next).to.include(\"offset=20\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"previous es null en la primera página\", () => {\r",
                  "    pm.expect(res.previous).to.be.null;\r",
                  "});\r",
                  "\r",
                  "// Guardar nombres de la página 1 para el test de no-repetición\r",
                  "pm.environment.set(\"page1_names\", JSON.stringify(res.results.map(p => p.name)));"
