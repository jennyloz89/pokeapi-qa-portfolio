                  "    pm.expect(res.damage_relations).to.have.all.keys(\r",
                  "        \"double_damage_from\", \"double_damage_to\",\r",
                  "        \"half_damage_from\", \"half_damage_to\",\r",
                  "        \"no_damage_from\", \"no_damage_to\"\r",
