      "name": "Functional Tests",
      "item": [
        {
          "name": "Pokémon by name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "// 1. Status code\r",
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Tiempo de respuesta\r",
                  "pm.test(\"Respuesta en menos de 2000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "// 3. Campos obligatorios presentes\r",
                  "pm.test(\"Campos obligatorios presentes\", () => {\r",
                  "    pm.expect(res).to.include.all.keys(\r",
                  "        \"id\", \"name\", \"types\", \"stats\", \r",
                  "        \"sprites\", \"abilities\", \"base_experience\", \r",
                  "        \"height\", \"weight\"\r",
                  "    );\r",
                  "});\r",
                  "\r",
                  "// 4. Tipos de dato correctos\r",
                  "pm.test(\"Tipos de dato correctos\", () => {\r",
                  "    pm.expect(res.id).to.be.a(\"number\");\r",
                  "    pm.expect(res.name).to.be.a(\"string\");\r",
                  "    pm.expect(res.types).to.be.an(\"array\").that.is.not.empty;\r",
                  "    pm.expect(res.stats).to.be.an(\"array\").that.is.not.empty;\r",
                  "});\r",
                  "\r",
                  "// 5. Datos conocidos de Pikachu (data integrity)\r",
                  "pm.test(\"Pikachu: ID, tipo y experiencia base correctos\", () => {\r",
                  "    pm.expect(res.id).to.eql(25);\r",
                  "    pm.expect(res.name).to.eql(\"pikachu\");\r",
                  "    pm.expect(res.types[0].type.name).to.eql(\"electric\");\r",
                  "    pm.expect(res.base_experience).to.eql(112);\r",
                  "});\r",
                  "\r",
                  "// 6. Sprites no son null\r",
                  "pm.test(\"Sprite frontal existe\", () => {\r",
                  "    pm.expect(res.sprites.front_default).to.be.a(\"string\").and.not.empty;\r",
                  "});\r",
                  "\r",
                  "// 7. Guardar ID para el test de equivalencia (Request 5)\r",
                  "pm.environment.set(\"pikachu_id\", res.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
